\geometry{
    a4paper,
    top=2.5cm,
    bottom=2.5cm,
    left=3.5cm,
    right=2.5cm,
    headheight=14pt,
    headsep=0.75cm,
    footskip=0.75cm
}

% Promenne pouzite pro titulni stranku
