% Formatovani nadpisu
\newcommand{\PrvniNadpis}{\fontsize{18}{22}\selectfont}
\newcommand{\DruhyNadpis}{\fontsize{15}{18}\selectfont}
\newcommand{\TretiNadpis}{\fontsize{12}{15}\selectfont}

\titleformat{\chapter}[block]{\normalfont\PrvniNadpis\bfseries}{\thechapter}{0.5em}{}
\titlespacing*{\chapter}{0pt}{12pt}{6pt}
\titleformat{\section}[block]{\normalfont\DruhyNadpis\bfseries}{\thesection}{0.5em}{}
\titlespacing*{\section}{0pt}{12pt}{6pt}
\titleformat{\subsection}[block]{\normalfont\TretiNadpis\bfseries}{\thesubsection}{0.5em}{}
\titlespacing*{\subsection}{0pt}{12pt}{6pt}

% Headers
\renewcommand{\headrulewidth}{0pt}
\fancyhead[L]{}
\fancyhead[R]{\textcolor[rgb]{0.5,0.5,0.5}{\textit{Vysoká škola polytechnická Jihlava}}}
\fancyfoot[C]{}
\fancyfoot[R]{\thepage}
\pagestyle{fancy}

\usepackage{caption}
\captionsetup[figure]{labelsep=colon, font={small,bf}, skip=6pt}
\captionsetup[table]{labelsep=colon, position=top, font={small,bf}, skip=6pt}
\counterwithout{figure}{chapter}
\counterwithout{table}{chapter}
\renewcommand{\figurename}{Obr.}
\renewcommand{\tablename}{Tab.}

\DeclareQuoteStyle{czech}{„}{“}{‚}{‘}
\setlength{\bibhang}{0pt}
\DeclareFieldFormat{url}{Dostupné z: \url{#1}}
\renewbibmacro*{note+url}{\newunit\newblock\printfield{note}\newunit\newblock\printfield{url}\newunit\newblock\printfield{organization}}
\AtBeginBibliography{\renewcommand*{\mkbibnamefamily}[1]{\MakeUppercase{#1}}}

