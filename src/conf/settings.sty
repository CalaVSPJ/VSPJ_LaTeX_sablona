% Formatovani nadpisu
\newcommand{\PrvniNadpis}{\fontsize{18}{22}\selectfont}                 % DOCX sz=36 -> 18pt
\newcommand{\DruhyNadpis}{\fontsize{15}{18}\selectfont}                 % DOCX sz=30 -> 15pt
\newcommand{\TretiNadpis}{\fontsize{12}{15}\selectfont}                 % DOCX sz=24 -> 12pt

\titleformat{\chapter}[block]
  {\normalfont\PrvniNadpis\bfseries}									% format nazvu kapitoly
  {\thechapter}{0.5em}{}												% format cislovani kapitoly
  \titlespacing*{\chapter}{0pt}{18pt}{6pt}
\titleformat{\section}[block]
  {\normalfont\DruhyNadpis\bfseries}									% format nazvu sekce
  {\thesection}{0.5em}{}												% format cislovani sekce
  \titlespacing*{\section}{0pt}{18pt}{6pt}
\titleformat{\subsection}[block]
  {\normalfont\TretiNadpis\bfseries}									% format nazvu subsekce
  {\thesubsection}{0.5em}{}												% format cislovani subsekce
  \titlespacing*{\subsection}{0pt}{18pt}{6pt}

% Formatovani zahlavi a zapati
\renewcommand{\headrulewidth}{0pt}
\fancyhead[L]{}
\fancyhead[R]{\textcolor[rgb]{0.5,0.5,0.5}{\textit{Vysoká škola polytechnická Jihlava}}}
\fancyfoot[C]{}
\fancyfoot[R]{\thepage}
\pagestyle{fancy}

% Numbering of figures and tables (global numbering Obr. 1 instead of Obr. 1.1)
\usepackage{caption}
\captionsetup[figure]{labelsep=colon}
\captionsetup[table]{labelsep=colon, position=top}
\counterwithout{figure}{chapter}
\counterwithout{table}{chapter}
\renewcommand{\figurename}{Obr.}
\renewcommand{\tablename}{Tab.}

% Nastaveni ceskych uvozovek
\DeclareQuoteStyle{czech}{„}{“}{‚}{‘}

% Pridani zdroje referenci a formatovani referenci
% https://www.citace.zcu.cz/caste-chyby.html
\setlength{\bibhang}{0pt}
\DeclareFieldFormat{url}{Dostupné z: \url{#1}}
\renewbibmacro*{note+url}{ 
  \newunit\newblock
  \printfield{note}
  \newunit\newblock
  \printfield{url}
  \newunit\newblock
  \printfield{organization}
}
\AtBeginBibliography{\renewcommand*{\mkbibnamefamily}[1]{\MakeUppercase{#1}}}
\newcounter{bibitemcounter}
\setcounter{bibitemcounter}{0}
\renewbibmacro*{begentry}{%
  \stepcounter{bibitemcounter}%
  \textbf{\thebibitemcounter.}\space
}

