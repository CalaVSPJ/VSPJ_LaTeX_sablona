% Formatovani nadpisu — velikosti dle DOCX (Nadpis1=18pt, Nadpis2=15pt, Nadpis3=12pt)
\newcommand{\PrvniNadpis}{\fontsize{18}{22}\selectfont}
\newcommand{\DruhyNadpis}{\fontsize{15}{18}\selectfont}
\newcommand{\TretiNadpis}{\fontsize{12}{15}\selectfont}

% Kapitoly číslované — [hang] se zarovnáním na 21.55pt dle DOCX (Nadpis1 indent-left/hanging)
\titleformat{\chapter}[hang]
  {\normalfont\PrvniNadpis\bfseries}
  {\makebox[21.55pt][l]{\thechapter}}
  {0pt}{}
% Kapitoly nečíslované — bez odsazení (styl Nzev/Title v DOCX)
\titleformat{name=\chapter,numberless}[block]
  {\normalfont\PrvniNadpis\bfseries}
  {}
  {0pt}{}
\titlespacing*{\chapter}{0pt}{18pt}{6pt}

% Podkapitoly číslované — [hang] se zarovnáním na 28.9pt dle DOCX (Nadpis2 indent-left/hanging)
\titleformat{\section}[hang]
  {\normalfont\DruhyNadpis\bfseries}
  {\makebox[28.9pt][l]{\thesection}}
  {0pt}{}
% Podkapitoly nečíslované
\titleformat{name=\section,numberless}[block]
  {\normalfont\DruhyNadpis\bfseries}
  {}
  {0pt}{}
\titlespacing*{\section}{0pt}{18pt}{6pt}

% Oddíly (Nadpis3) — bez hanging indent dle DOCX
\titleformat{\subsection}[block]
  {\normalfont\TretiNadpis\bfseries}
  {\thesubsection}{0.5em}{}
\titlespacing*{\subsection}{0pt}{18pt}{6pt}

% Nadpis stylu "Nzev" — 18pt tučně, 18pt před, 6pt po, BEZ zalomení stránky
% Používá se pro Klíčová slova, Abstract, Keywords uvnitř stránky Abstraktu
\newcommand{\nzev}[1]{%
  \par\vspace{18pt}%
  {\normalfont\PrvniNadpis\bfseries #1\par}%
  \vspace{6pt}%
}

